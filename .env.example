# ============================================================
#  Tock Reservation Bot — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ============================================================

# --- Tock account credentials ---
TOCK_EMAIL=your_email@example.com
TOCK_PASSWORD=your_password_here

# --- Notifications ---
# Discord webhook URL for booking alerts, sniper mode, errors, etc.
# Create one: Server Settings → Integrations → Webhooks → New Webhook
# Leave blank to disable Discord notifications (console logs always work).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# --- Browser mode ---
# true  = headless (runs silently in background, recommended for production)
# false = headed  (browser window visible, good for debugging / first run)
HEADLESS=false

# --- Dry-run mode ---
# true  = full flow (login → detect → select slot) but stops before confirming
# false = actually book the reservation
DRY_RUN=false

# --- Restaurant ---
RESTAURANT_SLUG=fui-hui-hua-san-francisco

# --- Booking preferences ---
PARTY_SIZE=2
PREFERRED_DAYS=Friday,Saturday,Sunday
PREFERRED_TIME=17:00      # 24-hour format; "17:00" = 5 PM
SCAN_WEEKS=4              # how many weeks ahead to scan

# --- Normal release window (moderate aggressive polling @ 60s) ---
# Use SNIPER mode for ultra-fast polling (see below).
RELEASE_WINDOW_DAYS=Monday
RELEASE_WINDOW_START=09:00
RELEASE_WINDOW_END=11:00

# --- Sniper mode (polls every ~3 seconds around known release times) ---
# Days to enter sniper mode (comma-separated, full English weekday names)
SNIPER_DAYS=Wednesday,Friday
# Start times (PT, 24-hour) to enter sniper mode — bot monitors from each time
# for SNIPER_DURATION_MIN minutes. Comma-separated; supports multiple windows.
# e.g. "16:59,19:59" covers both 5pm and 8pm PT release windows.
SNIPER_TIMES=16:59,19:59
# How many minutes each sniper window lasts (default: 11 minutes past start)
SNIPER_DURATION_MIN=11
# Sleep interval between polls during sniper mode (seconds, default: 3)
SNIPER_INTERVAL_SEC=3
